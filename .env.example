# ============================================================
# Variables de entorno de ejemplo — P2P Drop Radar
# Copia este archivo a .env y rellena los valores. NUNCA subas .env.
# En Cloudflare, los secretos se cargan con: wrangler secret put NOMBRE
# ============================================================

# Token del panel de administración (protege POST /api/config).
ADMIN_TOKEN=cambia_esto_por_un_token_largo_y_aleatorio

# Alertas por Telegram (opcional). Crea un bot con @BotFather.
TELEGRAM_BOT_TOKEN=123456789:AA_tu_token_de_bot
TELEGRAM_CHAT_ID=tu_chat_id_numerico

# Umbral de probabilidad para disparar alerta (%).
DROP_THRESHOLD=70

# Frecuencia lógica del muestreo (minutos). El cron real está en wrangler.toml.
INTERVAL_MINUTES=5
